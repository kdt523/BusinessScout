# Server Config
PORT=8000
HOST=0.0.0.0

# Remote server diagnostics/deployment helpers
REMOTE_HOST=207.148.13.164
REMOTE_USER=root
REMOTE_PORT=22
REMOTE_PASSWORD=

# Multi-Agent Mode (Set to true to run the local Band Room simulator)
USE_SIMULATOR=true

# AI Provider API Keys (Fill in at least one for real AI answers, otherwise fallback mocks are used)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=Qwen/Qwen2.5-7B-Instruct
AIMLAPI_API_KEY=
AIMLAPI_MODEL=deepseek-v4-flash

# Google Places / Maps API (Optional, geocoded global fallbacks are used if empty)
GOOGLE_MAPS_API_KEY=

# ---------------------------------------------------------------------------
# Real Band platform credentials (Required ONLY if USE_SIMULATOR=false)
#
# Register FOUR remote agents in the Band dashboard
# (New Agent -> Remote Agent) and paste each agent's UUID + API key below.
# Then run the agent processes:  python band_runner.py
# ---------------------------------------------------------------------------
BAND_REST_URL=https://app.band.ai
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# Legacy names are still accepted by band_runner.py as fallbacks.
THENVOI_REST_URL=
THENVOI_WS_URL=

BAND_ORCHESTRATOR_ID=
BAND_ORCHESTRATOR_KEY=
BAND_LOCATION_SCOUT_ID=
BAND_LOCATION_SCOUT_KEY=
BAND_COMPETITOR_ANALYST_ID=
BAND_COMPETITOR_ANALYST_KEY=
BAND_BUSINESS_PLANNER_ID=
BAND_BUSINESS_PLANNER_KEY=

# Bright Data Scraping Proxy Configuration (Optional, falls back to generic local-event presets if empty)
BRIGHTDATA_CUSTOMER_ID=
BRIGHTDATA_ZONE_NAME=
BRIGHTDATA_ZONE_PASSWORD=
BRIGHTDATA_PROXY_HOST=brd.superproxy.io
BRIGHTDATA_PROXY_PORT=22225
BRIGHTDATA_API_KEY=

